procedure TfrmClientesCreate.cxButton1Click(Sender: TObject);
begin
  inherited;

  MensajeError.CaptionOptions.Visible:= false;

  if qClientes.FieldByName('Nombres').AsString = '' then
    Begin
      MensajeError.CaptionOptions.Visible:= true;
      MensajeError.CaptionOptions.Text:= 'Especifique el nombre del cliente.';
      txtNombres.ValidateEdit(false);
      txtNombres.SetFocus;
      exit;
    End;

  if qClientes.FieldByName('TipoClienteId').AsInteger = 2 then
    if qClientes.FieldByName('Apellidos').AsString = '' then
      Begin
        MensajeError.CaptionOptions.Visible:= true;
        MensajeError.CaptionOptions.Text:= 'Especifique los apellidos del cliente.';
        txtApellidos.ValidateEdit(false);
        txtApellidos.SetFocus;
        exit;
      End;

  if qClientes.FieldByName('Documento').AsString = '' then
    Begin
      MensajeError.CaptionOptions.Visible:= true;
      MensajeError.CaptionOptions.Text:= 'Especifique el documento de identidad del cliente.';
      txtDocumento.ValidateEdit(false);
      txtDocumento.SetFocus;
      exit;
    End;

  if qClientes.FieldByName('Codigo').AsInteger = 0 then
    Begin

      qProximoCodigo.Close;
      qProximoCodigo.Open;

      qClientes.FieldByName('codigo').AsInteger:= qProximoCodigo.FieldByName('codigo').AsInteger;
     
    End;

  if qClientes.State in [dsEdit, dsInsert] then
    qClientes.Post;

  if imgFotoCliente.EditValue = Null then
    qFotos.Cancel;

  if qFotos.State in [dsEdit, dsInsert] then
    qFotos.Post;



  ModalResult:= mrOk;



end;

procedure TfrmClientesCreate.FormShow(Sender: TObject);
begin
  inherited;

  Titulo.Caption:= 'Nuevo cliente';
  if ClienteId>0 then
    Titulo.Caption:='Modificando cliente';

  frmClientesCreate.Caption:= Titulo.Caption;

  qTiposClientes.close;
  qTiposClientes.Open;

  qCategorias.Close;
  qCategorias.Open;

  qSexos.Close;
  qSexos.Open;

  qEstadosCiviles.Close;
  qEstadosCiviles.Open;

  qNacionalidades.Close;
  qNacionalidades.Open;

  qTipoNCF.Close;
  qTipoNCF.Open;

  qTerminosDePagos.Close;
  qTerminosDePagos.Open;

  qListadoDePrecios.Close;
  qListadoDePrecios.Open;

  qProvincias.Close;
  qProvincias.Open;

  qClientes.Close;
  qClientes.Parameters.ParamValues['ClienteId']:= ClienteId;
  qClientes.Open;

  if qClientes.RecordCount > 0 then
    qClientes.Edit
  else
    qClientes.Append;

  qFotos.Close;
  qFotos.Parameters.ParamValues['ClienteId']:= ClienteId;
  qFotos.Open;

  if qFotos.RecordCount > 0 then
    qFotos.Edit
  else
    qFotos.Append;


  cxDBLookupComboBox1.SetFocus;


end;

procedure TfrmClientesCreate.qClientesBeforePost(DataSet: TDataSet);
var i:Integer;
valorAnterior, valorNuevo:Variant;

begin
  inherited;


  qHistorialCambios.Close;
  qHistorialCambios.Open;

  for i := 0 to DataSet.FieldCount - 1 do
    begin

      if (DataSet.Fields[i].FieldKind = fkData)
       and (dmBaseDeDatos.CamposNoAuditables.IndexOf(DataSet.Fields[i].FieldName) = -1) then
        Begin

        valorAnterior:= DataSet.Fields[i].OldValue;
        valorNuevo:=DataSet.Fields[i].value;

        if  VarToStrDef(valorAnterior, '') <> VarToStrDef(valorNuevo, '') then
            begin
              qHistorialCambios.Insert;
              qHistorialCambios.FieldByName('HistorialId').AsInteger:= dmBaseDeDatos.GetProximoId('HistorialId');
              qHistorialCambios.FieldByName('Tabla').AsString:= 'Clientes';
              qHistorialCambios.FieldByName('ClavePrimaria').AsInteger:= DataSet.FieldByName('ClienteId').AsInteger;
              qHistorialCambios.FieldByName('Campo').AsString:= DataSet.Fields[i].FieldName;
              qHistorialCambios.FieldByName('ValorAnterior').AsString:= VarToStrDef(valorAnterior, '');
              qHistorialCambios.FieldByName('ValorNuevo').AsString:= VarToStrDef(valorNuevo, '');
              qHistorialCambios.FieldByName('Usuario').AsString:= dmBaseDeDatos.GetUsuarioActual;
              qHistorialCambios.FieldByName('FechaCambio').AsDateTime:= dmBaseDeDatos.GetFechaActual;
              qHistorialCambios.Post;
            end;
        End;
    end;









end;

procedure TfrmClientesCreate.qClientesNewRecord(DataSet: TDataSet);
begin
  inherited;

  qValoresPorDefecto.Close;
  qValoresPorDefecto.Open;

  DataSet.FieldByName('ClienteId').AsInteger:= dmBaseDeDatos.GetProximoId('ClienteId');
  DataSet.FieldByName('ClienteGuid').AsString:= dmBaseDeDatos.GetNuevoGUID;
  DataSet.FieldByName('Codigo').AsInteger:= 0;
  DataSet.FieldByName('TipoClienteId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesTipoClienteId').AsInteger;
  DataSet.FieldByName('CategoriaId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesCategoriaId').AsInteger;
  DataSet.FieldByName('TipoDocumentoId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesTipoDocumentoId').AsInteger;
  DataSet.FieldByName('SexoId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesSexoId').AsInteger;
  DataSet.FieldByName('EstadoCivilId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesEstadoCivilId').AsInteger;
  DataSet.FieldByName('TipoNCFId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesTipoNCFId').AsInteger;
  DataSet.FieldByName('TerminoPagoId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesTerminoDePagoId').AsInteger;
  DataSet.FieldByName('ListaPrecioId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesListaPrecioId').AsInteger;
  DataSet.FieldByName('ProvinciaId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesProvinciaId').AsInteger;
  DataSet.FieldByName('NacionalidadId').AsInteger:= qValoresPorDefecto.FieldByName('ClientesNAcionalidadId').AsInteger;

  DataSet.FieldByName('CreadoPor').AsString:= dmBaseDeDatos.GetUsuarioActual;
  DataSet.FieldByName('FechaCreacion').AsDateTime:= dmBaseDeDatos.GetFechaActual;
  DataSet.FieldByName('EstadoId').AsInteger:=1;






end;

