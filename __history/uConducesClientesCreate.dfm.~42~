  object qClientes: TADOQuery
    Connection = dmBaseDeDatos.db
    CursorType = ctStatic
    Parameters = <>
    SQL.Strings = (
      'Select *, concat(Nombres,'#39' '#39',Apellidos) NombreCompleto'
      ',concat(TelefonoCelular, '
      
        'case when TelefonoCelular is not null then  '#39', '#39' else '#39#39' end, Te' +
        'lefonoTrabajo,'
      
        'case when telefonoTrabajo is not null then  '#39', '#39' else '#39#39' end, Te' +
        'lefonoHogar) Telefonos'
      
        ',concat(documento, '#39' ('#39', d.TipoDocumento, '#39')'#39') DocumentoIdentida' +
        'd'
      ''
      'From Clientes a'
      
        'Inner join TiposDocumentos d on a.TipoDocumentoId = d.TipoDocume' +
        'ntoId')
    Left = 64
    Top = 32
  end
