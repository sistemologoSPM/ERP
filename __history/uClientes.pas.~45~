procedure TfrmClientes.btnClienteHistorialCambiosClick(Sender: TObject);
begin
  inherited;

  frmShadow:= TfrmShadow.Create(self);
  frmShadow.Show;


 frmClientesHistorial:= TfrmClientesHistorial.Create(self);
 frmClientesHistorial.ClienteId:=qClientes.FieldByName('ClienteId').AsInteger;
 frmClientesHistorial.ClienteNombre:= qClientes.FieldByName('NombreCliente').AsString;
 frmClientesHistorial.ShowModal;
 frmClientesHistorial.Release;

 frmShadow.Free;

end;

procedure TfrmClientes.btnClienteModificarClick(Sender: TObject);

begin
  inherited;
    inherited;



  frmShadow:= TfrmShadow.Create(self);
  frmShadow.Show;

  frmClientesCreate:= TfrmClientesCreate.Create(self);
  frmClientesCreate.ClienteId:=qClientes.FieldByName('ClienteId').AsInteger;;
  ClienteId:= frmClientesCreate.ShowModal;
  frmClientesCreate.Release;

  frmShadow.Free;

  qClientes.Close;
  qClientes.Open;

  qClientes.Locate('ClienteId',ClienteId, [] );
  GridListadoDBTableView1.Control.SetFocus;

end;

procedure TfrmClientes.btnInactivarClienteClick(Sender: TObject);
var
  Mensaje:String;
  EstadoId, ClienteId:Integer;

begin
  inherited;

  ClienteId:= qClientes.FieldByName('ClienteId').AsInteger;
  Mensaje:= '激sta seguro que desea deactivar el cliente?';
  EstadoId:= 2;

  if qClientes.FieldByName('EstadoId').AsInteger = 2 then
    Begin
       Mensaje:= '激sta seguro que desea activar el cliente?';
       EstadoId:= 1;
    End;

  frmMensaje:= TfrmMensaje.Create(self);
  frmMensaje.Mensaje:= Mensaje;

  if frmMensaje.ShowModal = mrOk then
    Begin
      ClientesActualizarEstado.Parameters.ParamValues['@ClienteId']:= ClienteId;
      ClientesActualizarEstado.Parameters.ParamValues['@EstadoId']:= EstadoId;
      ClientesActualizarEstado.Parameters.ParamValues['@Usuario']:= dmBaseDeDatos.GetUsuarioActual;

      ClientesActualizarEstado.ExecProc;

      qClientes.Close;
      qClientes.Open;

      qClientes.Locate('ClienteId', ClienteId,[] );
      GridListadoDBTableView1.Control.SetFocus;

    End;

  frmMensaje.Free;




end;

